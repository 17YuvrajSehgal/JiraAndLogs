# ============================================================================
# Agentic Incident Triage System — Environment Configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` (gitignored) and fill in real values.
# Never commit `.env`. Never commit API keys.
#
# Spec: DOCS/docs7/AGENTIC-SYSTEM.md §10 (LLM Provider) + §15 (Configuration).
# ============================================================================


# ----------------------------------------------------------------------------
# LLM PROVIDER
# ----------------------------------------------------------------------------
# Choose one provider:
#   lm_studio          — local LM Studio (default for our research dev)
#   openai             — OpenAI hosted (BYO key)
#   anthropic          — Anthropic Claude (BYO key)
#   ollama             — Ollama (local or cluster)
#   vllm               — vLLM (cluster-grade throughput)
#   generic_openai     — any OpenAI-compatible self-hosted endpoint
#
# The agent reads LLM_PROVIDER and dispatches to the matching adapter.
# API keys are read from provider-specific vars below — only the one matching
# LLM_PROVIDER is consulted, others can stay empty.

LLM_PROVIDER=lm_studio
LLM_BASE_URL=http://localhost:1234
LLM_MODEL=qwen/qwen3.6-35b-a3b

# Provider-specific API keys (one applies based on LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_KEY=
VLLM_API_KEY=


# ----------------------------------------------------------------------------
# ALTERNATIVE PROVIDER CONFIGS
# ----------------------------------------------------------------------------
# Uncomment one block to switch providers. Don't forget to comment out the
# default `lm_studio` block above when you do.

# --- OpenAI ----------------------------------------------------------------
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# --- Anthropic -------------------------------------------------------------
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_API_KEY=sk-ant-...

# --- Ollama (local or cluster) ---------------------------------------------
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen2.5:35b

# --- vLLM (cluster) --------------------------------------------------------
# LLM_PROVIDER=vllm
# LLM_BASE_URL=http://cedar-gpu-42:8000
# LLM_MODEL=qwen/qwen3.6-35b-a3b
# VLLM_API_KEY=

# --- Generic OpenAI-compatible ---------------------------------------------
# LLM_PROVIDER=generic_openai
# LLM_BASE_URL=https://<your-endpoint>/v1
# LLM_MODEL=<your-model-name>


# ----------------------------------------------------------------------------
# NEO4J
# ----------------------------------------------------------------------------
# Local Neo4j defaults shown. For Aura cloud, swap NEO4J_URI to the
# `neo4j+s://<id>.databases.neo4j.io` form and set NEO4J_PASSWORD.
#
# **Research safety rule (locked):** Only ONE dataset is loaded into the
# Neo4j instance at a time. The agent's startup integrity check
# (GraphMetadata fingerprint, see DOCS/docs7/IMPROVEMENTS.md §1.1) refuses
# to run if the loaded graph doesn't match the dataset being evaluated.

NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- Aura cloud variant ----------------------------------------------------
# NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
# NEO4J_USERNAME=<from Aura console>
# NEO4J_PASSWORD=<from Aura console>
# NEO4J_DATABASE=<from Aura console>

# **RESERVED — do not set during research evaluation.**
# Option B (tagged-node multi-tenancy) is reserved for future production
# multi-tenancy ONLY. The agent will refuse to start if this is set during
# a research run, because tagged-node filtering is too fragile for
# research-grade dataset isolation. See DOCS/docs7/IMPROVEMENTS.md §1.1.
NEO4J_DATASET_TAG=


# ----------------------------------------------------------------------------
# AGENT RUNTIME DIRECTORIES
# ----------------------------------------------------------------------------
# All have sensible defaults; override only if you need a different layout
# (e.g. when running on a cluster where /scratch is faster than the home dir).

# Per-experiment id; threaded through every telemetry record. If empty,
# the runner derives a timestamped default. OVERRIDE per run.
AGENT_EXPERIMENT=

# Where the agent writes per-window Trace JSONs.
AGENT_TRACE_DIR=data/agent_traces

# Content-addressed SkillCache; speeds up ablations enormously.
AGENT_CACHE_DIR=data/skill_cache

# Per-call LLM telemetry (tokens, latency, cost).
AGENT_LLM_TELEMETRY_DIR=data/llm_telemetry

# Path to the runtime YAML config. Defaults to ./agent-config.yaml if unset.
AGENT_CONFIG_PATH=agent-config.yaml
